# Base URL of the Go API, including the /api/v1 prefix.
#
# Leave unset in development: the Vite proxy (see vite.config.ts) forwards
# same-origin /api requests to the backend, which keeps the httpOnly auth
# cookies working without any CORS setup.
#
# Set it when the frontend is served from a different origin than the API.
# The API must then send Access-Control-Allow-Credentials for auth to work.
# VITE_API_BASE_URL=https://api.example.com/api/v1

# Where the dev proxy forwards /api. Only used by vite.config.ts.
# VITE_API_TARGET=http://localhost:3080
