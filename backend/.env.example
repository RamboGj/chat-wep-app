CHATAPP_DATABASE_HOST=localhost
CHATAPP_DATABASE_PORT=5432
CHATAPP_DATABASE_USER=postgres
CHATAPP_DATABASE_PASSWORD=postgres
CHATAPP_DATABASE_NAME=chatapp
# Generate a real secret for anything but local dev: openssl rand -base64 48
CHATAPP_JWT_SECRET=change-me-in-prod
CHATAPP_ACCESS_TOKEN_TTL=15m
CHATAPP_REFRESH_TOKEN_TTL=168h
CHATAPP_COOKIE_SECURE=false
# lax | none | strict. Lax works when the frontend shares a registrable domain
# with the API (app.example.com + api.example.com are same-site even though they
# are cross-origin). Use none only when the frontend is on an unrelated domain
# — those are third-party cookies, which Safari blocks by default, so some
# visitors will not be able to log in at all. Requires COOKIE_SECURE=true.
CHATAPP_COOKIE_SAMESITE=lax
CHATAPP_API_ADDR=localhost:3080

# Comma-separated browser origins allowed to open the /ws socket.
# Unset = same-origin only. Set this when the frontend is served separately.
CHATAPP_ALLOWED_ORIGINS=http://localhost:5173
